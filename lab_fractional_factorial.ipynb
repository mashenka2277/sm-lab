    "    \n",
    "    params[label] = {'x0': x0, 'dx': dx}\n",
    "    factors[label] = {'col': col, 'min': xmin, 'max': xmax, 'x0': x0, 'dx': dx}\n",
    "    \n",
    "    print(f\"{label} ({col}): [{xmin:.2f}, {xmax:.2f}] | Нул. рівень X0: {x0:.2f} | Інт. вар. ΔX: {dx:.2f}\")\n",
    "\n",
    "print(f\"\\ny ({TARGET}): [{df[TARGET].min()}, {df[TARGET].max()}]\")"
   ]
  },
  {
