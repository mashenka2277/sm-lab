   "source": [
    "params = {}\n",
    "\n",
    "print(\"Таблиця 1 — Області визначення факторів та вихідної змінної\\n\")\n",
    "\n",
    "factors = {}\n",
    "for label, col in FACTORS.items():\n",
    "    xmin, xmax = df[col].min(), df[col].max()\n",
    "    x0 = (xmax + xmin) / 2\n",
