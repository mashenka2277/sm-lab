   "source": [
    "variances = table2['S²'].values\n",
    "max_var = np.max(variances)\n",
    "sum_var = np.sum(variances)\n",
    "\n",
    "G_exp = max_var / sum_var\n",
    "\n",
    "N = 8          \n",
    "m = 5          \n",
    "f1 = m - 1     \n",
    "f2 = N         \n",
    "alpha = 0.05   \n",
    "\n",
    "F_val = stats.f.ppf(1 - alpha / N, f1, (N - 1) * f1)\n",
    "G_crit = 1 / (1 + (N - 1) / F_val)\n",
    "\n",
    "print(f\"Максимальна дисперсія (S²_max): {max_var:.4f}\")\n",
    "print(f\"Сума всіх дисперсій (ΣS²): {sum_var:.4f}\")\n",
    "print(f\"Розрахунковий критерій (Gp): {G_exp:.4f}\")\n",
    "print(f\"Критичне значення (G_crit): {G_crit:.4f}\")\n",
    "print(\"-\" * 38)\n",
    "\n",
    "if G_exp < G_crit:\n",
    "    print(\"Gp < G_crit: Дисперсії однорідні. Модель стабільна\")\n",
    "else:\n",
    "    print(\"Gp > G_crit: Дисперсії неоднорідні\")"
