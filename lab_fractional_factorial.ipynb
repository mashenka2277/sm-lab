   "source": [
    "**2. Аналіз quality**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 76,
   "id": "f516ec28",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
